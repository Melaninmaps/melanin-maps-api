<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%"   stop-color="#1A0A04"/>
      <stop offset="60%"  stop-color="#2D1206"/>
      <stop offset="100%" stop-color="#0D0502"/>
    </linearGradient>
    <linearGradient id="accent" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="#C4813A"/>
      <stop offset="100%" stop-color="#E8A84E"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Decorative circles -->
  <circle cx="1050" cy="100"  r="280" fill="#C4813A" opacity="0.06"/>
  <circle cx="150"  cy="530"  r="200" fill="#8B4513" opacity="0.08"/>
  <circle cx="900"  cy="500"  r="160" fill="#C4813A" opacity="0.04"/>

  <!-- Accent bar -->
  <rect x="80" y="140" width="80" height="6" rx="3" fill="url(#accent)"/>

  <!-- Title -->
  <text x="80" y="200" font-family="Georgia, serif" font-size="60" font-weight="700" fill="#FFFFFF">Mapping with Melanin™</text>

  <!-- Subtitle -->
  <text x="80" y="300" font-family="Arial, sans-serif" font-size="32" fill="#C4A882">Community-powered safety-first travel discovery for</text>
<text x="80" y="340" font-family="Arial, sans-serif" font-size="32" fill="#C4A882">Melinated travelers.</text>

  <!-- Bottom brand strip -->
  <rect x="0" y="560" width="1200" height="70" fill="#0D0502" opacity="0.7"/>
  <circle cx="80" cy="595" r="18" fill="url(#accent)"/>
  <text x="80" y="601" text-anchor="middle" font-family="Georgia, serif" font-size="18" font-weight="700" fill="#1A0A04">M</text>
  <text x="110" y="603" font-family="Georgia, serif" font-size="22" font-weight="700" fill="#FFFFFF">Mapping with Melanin™</text>
  <text x="1120" y="603" text-anchor="end" font-family="Arial, sans-serif" font-size="18" fill="#C4A882">mappingwithmelanin.com</text>
</svg>